# Oracle DB
DB_URL=jdbc:oracle:thin:@<tns_alias>
DB_USERNAME=
DB_PASSWORD=

# JWT
JWT_SECRET=

# Gemini AI
GEMINI_API_KEY=
GEMINI_API_MODEL=gemini-2.5-flash

# Telegram
TELEGRAM_BOT_TOKEN=

# Internal service URLs
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_BROKERCONNECT=kafka:29092
KPI_SERVICE_URL=http://kpi-service:8080
AUTH_SERVICE_URL=http://auth-service:8082
FEIGN_CLIENT_CONFIG_KPI_SERVICE_URL=http://kpi-service:8080

# Oracle Wallet
TNS_ADMIN=/app/Wallet
ORACLE_WALLET_PATH=/app/Wallet

# CORS
CORS_ALLOWED_ORIGINS=https://yourdomain.com,http://localhost:5173
